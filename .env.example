# PREVENTA SYSTEM - ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env.dev (development) or .env.prod (production)
# NEVER commit actual credentials to git

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://user:password@host:port/dbname"

# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxxxx

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate with: openssl rand -hex 32
JWT_SECRET=your-64-char-random-hex-string-here
REFRESH_SECRET=your-64-char-random-hex-string-here

# ============================================
# EMAIL SERVICE (RESEND)
# ============================================
RESEND_API_KEY=re_your_api_key_here

# ============================================
# USER CREDENTIALS
# ============================================
# Format: Uppercase + Symbol + Number + 14 chars minimum
# Example: Diez@Admin2024, Diez#Staff2024
ADMIN_PASSWORD=YourSecureAdminPassword123!
STAFF_PASSWORD=YourSecureStaffPassword456@
